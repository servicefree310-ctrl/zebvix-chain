{
  "name": "@workspace/zebvix-js",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Official TypeScript SDK for the Zebvix L1 blockchain. ZVM execution layer (Cancun-EVM-bytecode compatible). Thin ethers.js v6 extension exposing native zbx_* RPC methods alongside the standard Ethereum-spec eth_* / net_* / web3_* namespace.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "tsx tests/live.test.ts",
    "example:basic": "tsx examples/basic.ts",
    "example:wallet": "tsx examples/wallet.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "keywords": [
    "zebvix",
    "zvm",
    "blockchain",
    "ethers",
    "sdk",
    "web3",
    "zbx"
  ],
  "license": "MIT",
  "peerDependencies": {
    "ethers": "^6.13.0"
  },
  "dependencies": {
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:"
  }
}
