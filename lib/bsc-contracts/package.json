{
  "name": "@workspace/bsc-contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Solidity contracts for the Zebvix ↔ BSC bridge: WrappedZBX (BEP-20) + ZebvixBridge (M-of-N multisig).",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network bscTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network bsc",
    "deploy:dryrun": "hardhat run scripts/deploy.ts --network hardhat",
    "verify:testnet": "hardhat run scripts/verify.ts --network bscTestnet",
    "verify:mainnet": "hardhat run scripts/verify.ts --network bsc",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.11",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "solidity-coverage": "^0.8.1",
    "typechain": "^8.3.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "catalog:",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.18",
    "hardhat-gas-reporter": "^2.2.2",
    "mocha": "^10.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
